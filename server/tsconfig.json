{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",

		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"target": "ES2022",
		"types": ["node"],

		"sourceMap": true,

		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		"strict": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"skipLibCheck": true
	},
	"include": ["src"]
}
